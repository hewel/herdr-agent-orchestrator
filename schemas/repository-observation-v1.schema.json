{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://herdr.dev/schemas/harness-coordinator/repository-observation-v1.schema.json",
  "title": "RepositoryObservationV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_id",
    "checkpoint",
    "worktree_root",
    "git_common_dir",
    "head",
    "branch",
    "index_digest",
    "staged_diff",
    "unstaged_diff",
    "untracked",
    "ignored_paths",
    "status_entries",
    "changed_paths",
    "scope_classifications",
    "command_evidence",
    "captured_at",
    "digest"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "$ref": "common-v1.schema.json#/$defs/uuid" },
    "task_id": { "$ref": "common-v1.schema.json#/$defs/uuid" },
    "checkpoint": { "enum": ["before_dispatch", "result", "cancel", "failure", "approval", "hold_clear"] },
    "worktree_root": { "$ref": "common-v1.schema.json#/$defs/absolutePath" },
    "git_common_dir": { "$ref": "common-v1.schema.json#/$defs/absolutePath" },
    "head": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "branch": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 1024
    },
    "index_digest": { "$ref": "common-v1.schema.json#/$defs/sha256" },
    "staged_diff": {
      "oneOf": [
        { "$ref": "common-v1.schema.json#/$defs/attachmentId" },
        { "type": "null" }
      ]
    },
    "unstaged_diff": {
      "oneOf": [
        { "$ref": "common-v1.schema.json#/$defs/attachmentId" },
        { "type": "null" }
      ]
    },
    "untracked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "file_type", "size", "digest"],
        "properties": {
          "path": { "$ref": "common-v1.schema.json#/$defs/relativePath" },
          "file_type": { "enum": ["regular", "symlink", "other"] },
          "size": { "type": ["integer", "null"], "minimum": 0 },
          "digest": {
            "oneOf": [
              { "$ref": "common-v1.schema.json#/$defs/sha256" },
              { "type": "null" }
            ]
          }
        },
        "allOf": [
          {
            "if": { "properties": { "file_type": { "const": "regular" } } },
            "then": {
              "properties": {
                "size": { "type": "integer" },
                "digest": { "$ref": "common-v1.schema.json#/$defs/sha256" }
              }
            }
          }
        ]
      }
    },
    "ignored_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "common-v1.schema.json#/$defs/relativePath" }
    },
    "status_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "index_status", "worktree_status"],
        "properties": {
          "path": { "$ref": "common-v1.schema.json#/$defs/relativePath" },
          "index_status": { "type": "string", "minLength": 1, "maxLength": 2 },
          "worktree_status": { "type": "string", "minLength": 1, "maxLength": 2 },
          "original_path": {
            "oneOf": [
              { "$ref": "common-v1.schema.json#/$defs/relativePath" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "changed_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "common-v1.schema.json#/$defs/relativePath" }
    },
    "scope_classifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "classification", "matched_scope"],
        "properties": {
          "path": { "$ref": "common-v1.schema.json#/$defs/relativePath" },
          "classification": { "enum": ["in_scope", "out_of_scope"] },
          "matched_scope": {
            "oneOf": [
              { "$ref": "common-v1.schema.json#/$defs/writeScope" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "command_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "version", "exit_code", "diagnostics"],
        "properties": {
          "command": { "type": "string", "minLength": 1, "maxLength": 8192 },
          "version": { "type": "string", "minLength": 1, "maxLength": 256 },
          "exit_code": { "type": "integer" },
          "diagnostics": { "type": "string", "maxLength": 4096 }
        }
      }
    },
    "captured_at": { "$ref": "common-v1.schema.json#/$defs/rfc3339" },
    "digest": { "$ref": "common-v1.schema.json#/$defs/sha256" }
  }
}
